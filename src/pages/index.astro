---
import Layout from '@/layouts/Layout.astro';
import { getPublishedPosts, getPostSlug } from '@/lib/utils/posts';
import { getReadTime } from '@/lib/utils/readTime';
import { SITE } from '@/config';
import { Image } from 'astro:assets';
import profilePhoto from '@/site-assets/profile_photo.png';
import { readFileSync } from 'fs';
import { join } from 'path';
import { parseMarkdown } from '@/lib/simple-markdown';

const posts = (await getPublishedPosts()).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPosts = posts.filter((post) => post.data.featured).slice(0, SITE.featuredPostsCount);
const latestPosts = posts.filter((post) => !post.data.featured).slice(0, SITE.latestPostsCount);

const today = new Intl.DateTimeFormat('en-US', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(new Date());
---

<Layout title="Front Page">
  <!-- Newspaper Masthead -->
  <div class="border-b-4 border-foreground pb-4 md:pb-6 mb-8 text-center flex flex-col pt-4">
    <h1
      class="text-5xl sm:text-7xl md:text-8xl lg:text-[7rem] font-black font-serif uppercase tracking-tighter leading-none text-foreground my-2"
    >
      {SITE.title}
    </h1>

    <div
      class="mt-4 md:mt-6 border-t border-b border-foreground/50 py-2 flex flex-col sm:flex-row justify-between items-center text-xs md:text-sm font-serif italic text-muted-foreground gap-2 sm:gap-0 font-bold"
    >
      <span class="tracking-widest capitalize">Security Dispatches</span>
      <span class="tracking-widest uppercase">Special Edition</span>
      <span class="tracking-widest capitalize">Vulnerability Reports</span>
    </div>
  </div>

  <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 relative items-start">
    <!-- Left Column: Main Headline & Secondary Story -->
    <div class="lg:w-2/3 flex flex-col gap-10">
      <!-- Headline Story -->
      {
        posts.length > 0 &&
          (() => {
            const headlinePost = featuredPosts.length > 0 ? featuredPosts[0] : latestPosts[0];
            return (
              <article class="flex flex-col">
                <a
                  href={`/posts/${getPostSlug(headlinePost)}`}
                  class="group no-underline block max-w-3xl"
                >
                  <h2 class="text-4xl sm:text-5xl md:text-6xl font-black font-serif uppercase leading-[1.05] tracking-tight mb-4 group-hover:text-primary transition-colors hover:underline decoration-4 underline-offset-4">
                    {headlinePost.data.title}
                  </h2>
                </a>
                <div class="flex items-center gap-2 text-xs md:text-sm font-bold uppercase tracking-widest text-muted-foreground mb-6">
                  <span>By {SITE.author}</span>
                  <span class="text-primary">•</span>
                  <span>
                    {headlinePost.data.pubDate.toLocaleDateString('en-US', {
                      month: 'short',
                      day: 'numeric',
                      year: 'numeric',
                    })}
                  </span>
                  <span class="text-primary">•</span>
                  <span>{getReadTime(headlinePost.body || '')}</span>
                </div>

                <p class="text-lg md:text-xl font-serif leading-relaxed text-foreground first-letter:text-7xl first-letter:font-black first-letter:float-left first-letter:mr-3 first-letter:mt-1 first-letter:text-primary first-letter:font-serif">
                  {headlinePost.data.description}
                </p>
                <a
                  href={`/posts/${getPostSlug(headlinePost)}`}
                  class="mt-6 inline-block font-bold uppercase tracking-widest text-xs hover:text-primary hover:underline hover:bg-foreground hover:text-background border border-foreground/20 px-4 py-2 self-start transition-all"
                >
                  Read Full Dispatch →
                </a>
              </article>
            );
          })()
      }

      <!-- Secondary Featured Posts / Sub-headlines -->
      <div class="grid md:grid-cols-2 gap-8 border-t-[3px] border-foreground pt-8 mt-4">
        {
          (() => {
            // If we had a featured post for the headline, the second featured post is a sub-headline.
            // Otherwise, we take the next two recent posts.
            let subPosts =
              featuredPosts.length > 0
                ? [...featuredPosts.slice(1), ...latestPosts].filter(
                    (v, i, a) => a.findIndex((t) => t.id === v.id) === i
                  )
                : latestPosts.slice(1);

            return subPosts.slice(0, 2).map((post) => (
              <article class="flex flex-col">
                <a href={`/posts/${getPostSlug(post)}`} class="group no-underline">
                  <h3 class="text-2xl font-bold font-serif leading-tight mb-3 group-hover:text-primary group-hover:underline decoration-2 underline-offset-4">
                    {post.data.title}
                  </h3>
                </a>
                <div class="text-[10px] font-bold uppercase tracking-widest text-muted-foreground mb-3 opacity-80">
                  {post.data.pubDate.toLocaleDateString('en-US')}
                </div>
                <p class="text-[1.05rem] font-serif leading-snug mb-3 text-foreground/90">
                  {post.data.description}
                </p>
              </article>
            ));
          })()
        }
      </div>
    </div>

    <!-- Right Column: Editorial & Archives -->
    <div class="lg:w-1/3 flex flex-col gap-10 lg:pl-10 lg:border-l-[3px] lg:border-foreground">
      <!-- Edtorial Block (Profile Box) -->
      <div class="border-[3px] border-foreground p-6 bg-card relative mt-4 lg:mt-0">
        <div
          class="absolute -top-[16px] left-1/2 -translate-x-1/2 bg-card px-4 font-black uppercase tracking-[0.3em] text-sm text-foreground"
        >
          Editorial
        </div>
        <div class="flex justify-center mb-6 mt-2">
          <Image
            src={profilePhoto}
            alt={SITE.author}
            width={120}
            height={120}
            class="rounded-full w-28 h-28 object-cover border-[3px] border-foreground p-1 bg-white grayscale contrast-125"
          />
        </div>
        <div
          class="hero-content prose prose-sm prose-p:font-serif prose-p:leading-relaxed text-center mb-6"
          set:html={(() => {
            try {
              const fullPath = join(process.cwd(), SITE.hero.filePath);
              const markdown = readFileSync(fullPath, 'utf-8');
              return parseMarkdown(markdown.replace('{author}', SITE.author));
            } catch (e) {
              return `<p>${SITE.homeHeroDescription}</p>`;
            }
          })()}
        />
        <div class="flex flex-wrap justify-center gap-4 border-t border-border pt-4">
          {
            Object.entries(SITE.social).map(([platform, link]) => (
              <a
                href={link}
                class="text-[10px] font-bold uppercase tracking-[0.2em] text-muted-foreground hover:text-primary transition-colors hover:underline"
              >
                [{platform}]
              </a>
            ))
          }
        </div>
      </div>

      <!-- Latest Briefs Sidebar -->
      <div class="flex flex-col">
        <h3
          class="text-xl font-black font-serif uppercase tracking-widest border-b-2 border-foreground pb-2 mb-6"
        >
          Latest Briefs
        </h3>
        <div class="flex flex-col gap-6">
          {
            (() => {
              // Find posts that haven't been shown in the left column
              const shownCount = Math.min(posts.length, 3);
              const remaining = posts.slice(shownCount, shownCount + 4);
              return remaining.map((post) => (
                <article class="border-b border-border/50 pb-4 last:border-0 last:pb-0">
                  <div class="text-[9px] uppercase font-bold tracking-widest text-primary mb-1">
                    {post.data.pubDate.toLocaleDateString('en-US', {
                      month: 'short',
                      day: 'numeric',
                      year: 'numeric',
                    })}
                  </div>
                  <a href={`/posts/${getPostSlug(post)}`} class="group no-underline">
                    <h4 class="text-lg font-bold font-serif leading-tight group-hover:text-primary group-hover:underline underline-offset-2">
                      {post.data.title}
                    </h4>
                  </a>
                </article>
              ));
            })()
          }

          <a
            href="/posts"
            class="block w-full text-center border-2 border-foreground py-3 text-xs font-bold uppercase tracking-widest hover:bg-foreground hover:text-background transition-all hover:scale-[1.02]"
          >
            View All Archives
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .hero-content :global(h1) {
    font-size: 1.5rem;
    line-height: 1.2;
    font-family: var(--font-serif);
    font-weight: 800;
    margin-bottom: 0.75rem;
    color: var(--color-foreground);
    text-align: center;
    text-transform: uppercase;
  }

  .hero-content :global(p) {
    font-size: 1.05rem;
    line-height: 1.6;
    color: var(--color-foreground);
    margin-bottom: 1rem;
    text-align: justify;
    text-align-last: center;
  }
</style>
