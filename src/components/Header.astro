---
import { SITE } from '@/config';
import Search from '@/components/Search.svelte';

interface NavLink {
  name: string;
  href: string;
}

const navLinks: NavLink[] = [
  { name: 'Posts', href: `${SITE.base === '/' ? '' : SITE.base}/posts` },
  { name: 'About', href: `${SITE.base === '/' ? '' : SITE.base}/about` },
];
---

<header
  class="sticky top-0 z-50 bg-background flex flex-col sm:flex-row items-center justify-between py-3 px-0 border-b-[3px] border-foreground transition-all duration-300"
>
  <div class="flex items-center justify-between w-full sm:w-auto">
    <a
      href={SITE.base === '/' ? '/' : SITE.base}
      class="text-2xl sm:text-3xl font-black font-serif uppercase tracking-tighter text-foreground transition-all no-underline hover:text-primary whitespace-nowrap decoration-2 underline-offset-4"
    >
      0x1337
    </a>
    <div class="flex items-center gap-2 sm:hidden">
      <Search client:idle />
    </div>
  </div>

  <nav class="flex flex-col sm:flex-row items-center gap-4 sm:gap-6 w-full sm:w-auto mt-4 sm:mt-0">
    <div class="flex items-center justify-center flex-wrap gap-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-xs font-bold font-sans uppercase tracking-[0.15em] text-foreground hover:text-primary hover:underline underline-offset-4 decoration-2 transition-all shrink-0"
          >
            {link.name}
          </a>
        ))
      }
    </div>
    <div class="hidden sm:block h-5 w-px bg-foreground/30"></div>
    <div class="hidden sm:flex items-center gap-4">
      <Search client:idle />
    </div>
  </nav>
</header>
