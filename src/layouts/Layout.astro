---
import '@/styles/global.css';
import { SITE } from '@/config';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import SearchModal from '@/components/SearchModal.svelte';
import { ClientRouter } from 'astro:transitions';
import JsonLd from '@/components/JsonLd.astro';
import { getWebSiteSchema, getOrganizationSchema, getPersonSchema } from '@/lib/schemas';

// Removed default fonts mapping

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  lang?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description, ogImage, lang, schema } = Astro.props;
const pageLang = lang || SITE.lang;
const pageTitle = title ? `${title} | ${SITE.title}` : SITE.title;
const pageDescription = description || SITE.desc;
const pageOgImage = new URL(ogImage || SITE.ogImage, Astro.site);

const defaultSchemas = [
  getWebSiteSchema(new URL(Astro.url.pathname, Astro.site).toString()),
  getOrganizationSchema(),
  getPersonSchema(),
];

const finalSchema = schema
  ? Array.isArray(schema)
    ? [...defaultSchemas, ...schema]
    : [...defaultSchemas, schema]
  : defaultSchemas;

const analyticsId = SITE.googleAnalyticsId;
const isGTM = analyticsId?.startsWith('GTM-');

const gtmScript = `
  (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
  new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
  j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
  'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
  })(window,document,'script','dataLayer','${analyticsId}');
`;

const gaScript = `
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', '${analyticsId}');
`;
---

<html lang={pageLang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={`${SITE.base === '/' ? '' : SITE.base}/favicon.png`} />
    <link
      rel="apple-touch-icon"
      href={`${SITE.base === '/' ? '' : SITE.base}/apple-touch-icon.png`}
    />
    <link rel="manifest" href={`${SITE.base === '/' ? '' : SITE.base}/site.webmanifest`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    <!-- SEO -->
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content={SITE.author} />
    <meta name="theme-color" content="#080808" />

    <!-- RSS Feed -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.title} RSS Feed`}
      href={`${SITE.base === '/' ? '' : SITE.base}/rss.xml`}
    />

    <!-- Theme Initialization -->
    <script is:inline>
      (function () {
        // Enforce dark mechanism in DOM for components that might rely on it
        document.documentElement.classList.remove('light');
        document.documentElement.classList.add('dark');
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={pageOgImage} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={pageOgImage} />

    {
      analyticsId && (
        <script type="text/partytown" is:inline set:html={isGTM ? gtmScript : gaScript} />
      )
    }

    <JsonLd schema={finalSchema} />

    <ClientRouter fallback="swap" />
    <base href={SITE.base} />
  </head>
  <body
    class="bg-background text-foreground min-h-screen relative overflow-x-hidden selection:bg-primary/20 selection:text-primary"
  >
    {
      isGTM && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${analyticsId}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
          />
        </noscript>
      )
    }
    <div class="max-w-5xl lg:max-w-6xl xl:max-w-7xl 2xl:max-w-[96rem] mx-auto container-padding">
      <Header />
      <main class="py-6 sm:py-8 lg:py-12">
        <slot />
      </main>
      <Footer />
      <SearchModal client:idle />
    </div>
  </body>
</html>
